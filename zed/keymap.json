// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      "alt-x": "command_palette::Toggle" // M-x
    }
  },
  {
    "bindings": {
      "shift-super-c": "workspace::CopyRelativePath",
      "alt-ctrl-p": "editor::MoveLineUp",
      "alt-ctrl-n": "editor::MoveLineDown",
      "alt-e": "editor::Copy",
      "alt-w": ["workspace::SendKeystrokes", "alt-e escape"],
      "ctrl-q": "editor::Cut",
      "ctrl-w": ["workspace::SendKeystrokes", "ctrl-q escape"],
    }
  }
]
